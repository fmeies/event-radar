# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-key

# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# https://brave.com/search/api/ (Free tier: 2000 queries/month)
BRAVE_API_KEY=your-brave-search-api-key

# https://www.perplexity.ai/settings/api (required for SEARCH_MODE=sonar)
PERPLEXITY_API_KEY=pplx-...

# Perplexity model used by the sonar engine. "sonar" is the cheap, shallow
# default; "sonar-pro" searches deeper (more sources) at higher per-call cost.
PERPLEXITY_MODEL=sonar

DATABASE_URL=sqlite:////data/event_radar.db

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
FROM_EMAIL=noreply@yourdomain.com

# Receives a notification email when a new user registers.
# Defaults to FROM_EMAIL if left empty.
ADMIN_EMAIL=admin@yourdomain.com

# Public URL of this instance, including any URL prefix (used in verification emails)
# Example with prefix: https://yourdomain.com/event-radar
BASE_URL=http://localhost:8000

# URL prefix when served under a sub-path (e.g. /event-radar). Leave empty for root.
ROOT_PATH=

# Comma-separated engine chain, tried in order until one returns results.
# Available engines:
#   claude       — Claude web search + Claude extraction (Anthropic only)
#   brave_claude — Brave Search + Claude extraction (needs both API keys)
#   sonar        — Perplexity Sonar search + extraction (Perplexity only)
# Examples: claude,brave_claude  |  sonar,claude,brave_claude  |  brave_claude
SEARCH_MODE=claude,brave_claude

# Set to true once HTTPS is in place — enforces Secure flag on the session cookie
SECURE_COOKIES=false
