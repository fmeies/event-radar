# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-key

# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# https://brave.com/search/api/ (Free tier: 2000 queries/month)
BRAVE_API_KEY=your-brave-search-api-key

DATABASE_URL=sqlite:////data/event_radar.db

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
FROM_EMAIL=noreply@yourdomain.com

# Public URL of this instance, including any URL prefix (used in verification emails)
# Example with prefix: https://yourdomain.com/event-radar
BASE_URL=http://localhost:8000

# URL prefix when served under a sub-path (e.g. /event-radar). Leave empty for root.
ROOT_PATH=

# Search mode: "claude" (Claude web search, Brave as fallback) or "brave" (Brave only)
SEARCH_MODE=claude

# Comma-separated list of websites Claude should prefer when searching for events.
# Example: SEARCH_SITES=ra.co,ticketmaster.de,eventim.de
SEARCH_SITES=

# Set to true once HTTPS is in place — enforces Secure flag on the session cookie
SECURE_COOKIES=false
